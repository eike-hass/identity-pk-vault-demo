# Copy this file to .env.local to enable mock/dev mode.
#
# When VITE_USE_MOCK=true:
#   - The dApp Kit "Unsafe Burner Wallet" is registered and auto-connected.
#   - Transactions are signed in-memory without any browser wallet extension.
#   - A dev-mode banner appears showing the burner address and a faucet link.
#
# You still need a running IOTA node. Start a local one with:
#   RUST_LOG="off,iota_node=info" iota start --force-regenesis --with-faucet
#
# Then fund the burner address shown in the banner via the faucet link,
# and set the network selector in the app to "Localnet".
VITE_USE_MOCK=true
